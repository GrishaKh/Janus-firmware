// Secrets.h — DEVICE-SPECIFIC credentials. Copy this file to Secrets.h
// (which is gitignored) and fill in real values before flashing.
//
// Get DEVICE_ID and RAW_TOKEN by:
//   1. Run `pnpm seed` in the Janus backend, OR mint a device in /admin.
//   2. Copy the bearer (looks like `demo-front-door.demo-token-front-door-...`).
//   3. Split on the FIRST dot: left = DEVICE_ID, right = RAW_TOKEN.
//
// Compile-only / CI builds use these placeholders unchanged — they fail
// at runtime (network refuses), not at compile time.
#pragma once

#define WIFI_SSID    "YOUR_WIFI_SSID"
#define WIFI_PASS    "YOUR_WIFI_PASSWORD"

// Seed-script defaults — replace with the bearer your admin dashboard issued.
#define DEVICE_ID    "demo-front-door"
#define RAW_TOKEN    "demo-token-front-door-7f3a9b1c4e8d2a6b"

// No trailing slash. Production points at the deployed Vercel URL.
#define API_BASE_URL "https://janus-green.vercel.app"
